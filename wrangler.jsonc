{
  "name": "investor-agent",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-20",
  "compatibility_flags": ["nodejs_compat"],
  // Polyfill __dirname for CJS dependencies (e.g. @deno/shim-deno via yahoo-finance2)
  "define": {
    "__dirname": "\"/\""
  },
  "durable_objects": {
    "bindings": [
      {
        "name": "MCP_OBJECT",
        "class_name": "InvestorAgent"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["InvestorAgent"]
    }
  ],
  // Create with: wrangler kv namespace create CACHE
  // Then paste the returned id below.
  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "5af9bc599b75477bb9d810619ca28be9"
    }
  ],
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ],
  "observability": {
    "enabled": true
  },
  // Custom domain — requires a CNAME record in Cloudflare DNS:
  // investor.ferdousbhai.com → investor-agent.<account>.workers.dev
  "routes": [
    {
      "pattern": "investor.ferdousbhai.com",
      "custom_domain": true
    }
  ]
}
